# Supabase — server-only, never sent to the browser
# Find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# reCAPTCHA v3
# Site key is public (loaded in the browser to generate tokens)
# Secret key is server-only (used to verify tokens)
# Get both at: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key-here
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key-here
